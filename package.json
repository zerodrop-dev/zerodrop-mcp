{
  "name": "zerodrop-mcp",
  "version": "0.1.0",
  "description": "MCP server for ZeroDrop — gives AI agents disposable email inboxes with auto-extracted OTPs and magic links. Verify signups, test auth flows, no Docker, no signup.",
  "type": "module",
  "bin": {
    "zerodrop-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "email-testing",
    "otp",
    "magic-link",
    "email-verification",
    "claude",
    "cursor",
    "zerodrop"
  ],
  "author": "ZeroDrop <founder@zerodrop.dev> (https://zerodrop.dev)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zerodrop-dev/zerodrop-mcp.git"
  },
  "homepage": "https://zerodrop.dev",
  "bugs": {
    "url": "https://github.com/zerodrop-dev/zerodrop-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
