{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-10-17/server.schema.json",
  "name": "dev.zerodrop/zerodrop-mcp",
  "title": "ZeroDrop",
  "description": "Disposable email inboxes for AI agents — OTPs and magic links auto-extracted. No signup needed.",
  "version": "0.1.2",
  "repository": {
    "url": "https://github.com/zerodrop-dev/zerodrop-mcp",
    "source": "github"
  },
  "websiteUrl": "https://zerodrop.dev",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "zerodrop-mcp",
      "version": "0.1.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "ZERODROP_API_KEY",
          "description": "ZeroDrop Workspace API key. Omit for free sandbox mode.",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "ZERODROP_BASE_URL",
          "description": "Override for self-hosted ZeroDrop instances.",
          "isRequired": false,
          "isSecret": false
        }
      ]
    }
  ]
}
